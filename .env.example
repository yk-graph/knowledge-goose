# =====================================================
# .env.example
#
# Copy this file to .env.local and fill in actual values.
# Never commit .env.local or any file containing secrets.
# =====================================================

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ----- Database (PostgreSQL) -----
# Local Docker (matches docker-compose.yml):
#   postgres://app:app@localhost:5432/knowledge_goose
# Production (AWS RDS):
#   postgres://<user>:<password>@<rds-endpoint>:5432/<db-name>?sslmode=require
DATABASE_URL=postgres://app:app@localhost:5432/knowledge_goose

# ----- better-auth -----
# Generate a strong random secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=
# Base URL for callback construction. In production, set to the deployed origin.
BETTER_AUTH_URL=http://localhost:3000

# ----- Google OAuth (for better-auth Google provider) -----
# Create OAuth 2.0 Client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Google Places API (server-side) -----
# Used by the Server Actions / API route that proxies Place searches.
# This key MUST NOT be exposed to the frontend.
# Restrict by IP and API in Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# ----- Google Maps JavaScript API (client-side) -----
# Public key embedded in the browser. MUST be domain-restricted in
# Google Cloud Console (HTTP referrers) and limited to the Maps JS API only.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ----- Resend (transactional email) -----
# Get API key at https://resend.com/api-keys
RESEND_API_KEY=
# The verified sender domain configured in Resend.
# For early testing, you can use Resend's onboarding domain.
RESEND_FROM_EMAIL=noreply@example.com
